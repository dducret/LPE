RUST_LOG=info
LPE_BIND_ADDRESS=127.0.0.1:8080
LPE_LOCAL_BIND_HOST=127.0.0.1
LPE_LOCAL_BIND_PORT=8080
# Internal cleartext IMAP listener used by the LPE-CT public IMAPS proxy.
# Keep this private. In a split DMZ/LAN topology, bind it to the core LPE
# private LAN address, for example 192.168.1.25:1143, and allow only LPE-CT
# to connect to it. The default is valid only for co-located LPE/LPE-CT tests.
LPE_IMAP_BIND_ADDRESS=127.0.0.1:1143
LPE_IMAP_BIND_HOST=127.0.0.1
LPE_IMAP_BIND_PORT=1143
LPE_SERVER_NAME=
LPE_NGINX_LISTEN_PORT=80
LPE_DB_HOST=localhost
LPE_DB_PORT=5432
LPE_DB_NAME=lpe
LPE_DB_USER=lpe
LPE_DB_PASSWORD=
# When left empty, the install and maintenance scripts derive DATABASE_URL from
# LPE_DB_HOST, LPE_DB_PORT, LPE_DB_NAME, LPE_DB_USER, and LPE_DB_PASSWORD.
# Effective default with the shipped DB defaults is:
# postgres://lpe:<password>@localhost:5432/lpe
DATABASE_URL=
LPE_INTEGRATION_SHARED_SECRET=
# Canonical outbound handoff from LPE to LPE-CT.
# The worker posts to:
#   ${LPE_CT_API_BASE_URL}/api/v1/integration/outbound-messages
# Default LPE-CT management/API port: 8380. In HA, point this at the LPE-CT
# private management/API VIP, not at an SMTP relay port.
# LPE_CT_API_BASE_URL=http://10.20.10.40:8380
# Optional HA role gating for active/passive keepalived-style failover.
# When enabled, /health/ready returns ready only when the file contains "active".
# LPE_HA_ROLE_FILE=/var/lib/lpe/ha-role
# Used by automatic bootstrap when no admin exists yet.
LPE_BOOTSTRAP_ADMIN_EMAIL=
LPE_BOOTSTRAP_ADMIN_DISPLAY_NAME='Bootstrap Administrator'
LPE_BOOTSTRAP_ADMIN_PASSWORD=
LPE_ADMIN_SESSION_MINUTES=45
LPE_PST_IMPORT_DIR=/var/lib/lpe/imports
LPE_PST_UPLOAD_MAX_BYTES=21474836480
LPE_NGINX_CLIENT_MAX_BODY_SIZE=20g
LPE_MAGIKA_BIN=/opt/lpe/bin/magika
LPE_MAGIKA_MIN_SCORE=0.80
LPE_PUBLIC_SCHEME=https
# Defaults to the request Host / X-Forwarded-Host when unset.
# LPE_PUBLIC_HOSTNAME=
# Thunderbird publishes IMAP by default. Configure SMTP only when you
# expose a real authenticated client-submission endpoint.
# LPE_AUTOCONFIG_IMAP_HOST=
# LPE_AUTOCONFIG_IMAP_PORT=993
# LPE_AUTOCONFIG_SMTP_HOST=
# LPE_AUTOCONFIG_SMTP_PORT=465
# LPE_AUTOCONFIG_SMTP_SOCKET_TYPE=SSL
# LPE_AUTODISCOVER_ACTIVESYNC_URL=
