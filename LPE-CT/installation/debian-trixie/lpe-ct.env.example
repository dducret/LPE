LPE_CT_BIND_ADDRESS=127.0.0.1:8380
LPE_CT_BIND_HOST=127.0.0.1
LPE_CT_BIND_PORT=8380
LPE_CT_SMTP_BIND_ADDRESS=0.0.0.0:25
LPE_CT_SMTP_HOST=0.0.0.0
LPE_CT_SMTP_PORT=25
# Configure only when authenticated client submission is really exposed.
# Preferred endpoint: implicit TLS on port 465.
# LPE_CT_SUBMISSION_BIND_ADDRESS=0.0.0.0:465
# LPE_CT_SUBMISSION_TLS_CERT_PATH=/etc/lpe-ct/tls/fullchain.pem
# LPE_CT_SUBMISSION_TLS_KEY_PATH=/etc/lpe-ct/tls/privkey.pem
# LPE_CT_SUBMISSION_MAX_MESSAGE_SIZE_MB=64
LPE_CT_SERVER_NAME=
LPE_CT_PUBLIC_HOSTNAME=
LPE_CT_NGINX_LISTEN_PORT=80
LPE_CT_STATE_FILE=/var/lib/lpe-ct/state.json
LPE_CT_SPOOL_DIR=/var/spool/lpe-ct
# Dedicated private PostgreSQL for technical LPE-CT-only state.
# This is the default persisted store for greylisting, reputation, bayespam,
# throttle windows, and quarantine metadata. It must stay private.
LPE_CT_LOCAL_DB_ENABLED=true
LPE_CT_LOCAL_DB_HOST=127.0.0.1
LPE_CT_LOCAL_DB_PORT=5432
LPE_CT_LOCAL_DB_NAME=lpe_ct
LPE_CT_LOCAL_DB_USER=lpe_ct
LPE_CT_LOCAL_DB_PASSWORD=strong-password
# Examples of accepted private scopes:
# host-local, private-backend, lpe-ct-cluster
LPE_CT_LOCAL_DB_NETWORK_SCOPE=host-local
LPE_CT_LOCAL_DB_LISTEN_ADDRESS=127.0.0.1:5432
# Runtime connection string used by LPE-CT to persist technical perimeter state
# into the private local PostgreSQL store. Queue ownership and payload custody
# remain in the spool.
LPE_CT_LOCAL_DB_URL=postgres://lpe_ct:strong-password@127.0.0.1:5432/lpe_ct
LPE_CT_LOCAL_DB_PURPOSES=bayesian,reputation,greylisting,quarantine-metadata,cluster-coordination
# Set to true only for disposable MVP environments where update-lpe-ct.sh
# must wipe the local state file and mail spool before redeploy.
LPE_CT_RESET_STATE_ON_UPDATE=false
LPE_CT_BOOTSTRAP_ADMIN_EMAIL=
LPE_CT_BOOTSTRAP_ADMIN_PASSWORD=
# Optional HA role gating for active/passive keepalived-style failover.
# When enabled, /health/ready returns ready only when the file contains "active".
# LPE_CT_HA_ROLE_FILE=/var/lib/lpe-ct/ha-role
# In an active/passive deployment, point to the core LAN VIP.
# LPE_CT_CORE_DELIVERY_BASE_URL=http://127.0.0.1:8080
LPE_CT_RELAY_PRIMARY=smtp://10.20.0.12:2525
LPE_CT_RELAY_SECONDARY=smtp://10.20.0.13:2525
LPE_INTEGRATION_SHARED_SECRET=
LPE_CT_MUTUAL_TLS_REQUIRED=false
LPE_CT_FALLBACK_TO_HOLD_QUEUE=false
LPE_CT_DRAIN_MODE=false
LPE_CT_GREYLISTING_ENABLED=true
LPE_CT_ANTIVIRUS_ENABLED=true
LPE_CT_ANTIVIRUS_FAIL_CLOSED=true
LPE_CT_ANTIVIRUS_PROVIDER_CHAIN=takeri
LPE_CT_ANTIVIRUS_TAKERI_BIN=/opt/lpe-ct/bin/Shuhari-CyberForge-CLI
LPE_CT_ANTIVIRUS_TAKERI_ARGS=takeri,scan
LPE_CT_ANTIVIRUS_TAKERI_REPO_URL=https://github.com/AnimeForLife191/Shuhari-CyberForge.git
LPE_CT_ANTIVIRUS_TAKERI_BRANCH=main
LPE_CT_ANTIVIRUS_TAKERI_SYNC_DIR=/opt/lpe-ct/vendor/takeri-src
# Example second provider chained after takeri:
# LPE_CT_ANTIVIRUS_PROVIDER_CHAIN=takeri,clamdscan
# LPE_CT_ANTIVIRUS_CLAMDSCAN_BIN=/usr/bin/clamscan
# LPE_CT_ANTIVIRUS_CLAMDSCAN_ARGS=--stdout,--no-summary,{path}
# LPE_CT_ANTIVIRUS_CLAMDSCAN_INFECTED_MARKERS=found
# LPE_CT_ANTIVIRUS_CLAMDSCAN_SUSPICIOUS_MARKERS=suspicious
# LPE_CT_ANTIVIRUS_CLAMDSCAN_CLEAN_MARKERS=ok
LPE_CT_BAYESPAM_ENABLED=true
LPE_CT_BAYESPAM_AUTO_LEARN=true
LPE_CT_BAYESPAM_SCORE_WEIGHT=6.0
LPE_CT_BAYESPAM_MIN_TOKEN_LENGTH=3
LPE_CT_BAYESPAM_MAX_TOKENS=256
LPE_CT_REQUIRE_SPF=true
LPE_CT_REQUIRE_DKIM_ALIGNMENT=false
LPE_CT_REQUIRE_DMARC_ENFORCEMENT=true
LPE_CT_DEFER_ON_AUTH_TEMPFAIL=true
LPE_CT_DNSBL_ENABLED=true
LPE_CT_DNSBL_ZONES=zen.spamhaus.org,bl.spamcop.net
LPE_CT_REPUTATION_ENABLED=true
LPE_CT_REPUTATION_QUARANTINE_THRESHOLD=-4
LPE_CT_REPUTATION_REJECT_THRESHOLD=-8
LPE_CT_SPAM_QUARANTINE_THRESHOLD=5.0
LPE_CT_SPAM_REJECT_THRESHOLD=9.0
LPE_CT_MAX_MESSAGE_SIZE_MB=64
# Used by check-lpe-ct.sh for a real SMTP delivery probe.
# LPE_CT_SMTP_TEST_SENDER=
# LPE_CT_SMTP_TEST_RECIPIENT=
RUST_LOG=info
LPE_MAGIKA_BIN=/opt/lpe-ct/bin/magika
LPE_MAGIKA_MIN_SCORE=0.80
