LPE_CT_BIND_ADDRESS=127.0.0.1:8380
LPE_CT_BIND_HOST=127.0.0.1
LPE_CT_BIND_PORT=8380
LPE_CT_SMTP_BIND_ADDRESS=0.0.0.0:25
LPE_CT_SMTP_HOST=0.0.0.0
LPE_CT_SMTP_PORT=25
# Authenticated client submission is terminated by LPE-CT on implicit TLS 465.
LPE_CT_SUBMISSION_BIND_ADDRESS=0.0.0.0:465
# These may reuse LPE_CT_PUBLIC_TLS_CERT_PATH and LPE_CT_PUBLIC_TLS_KEY_PATH
# when the same public hostname is used.
LPE_CT_SUBMISSION_TLS_CERT_PATH=/etc/lpe-ct/tls/fullchain.pem
LPE_CT_SUBMISSION_TLS_KEY_PATH=/etc/lpe-ct/tls/privkey.pem
LPE_CT_SUBMISSION_MAX_MESSAGE_SIZE_MB=64
LPE_CT_SERVER_NAME=
LPE_CT_PUBLIC_HOSTNAME=
# HTTPS listener. Do not set this to 80; nginx reserves 80 for HTTP redirects.
LPE_CT_NGINX_LISTEN_PORT=443
# Certificate used by nginx for the public HTTPS edge on 443.
LPE_CT_PUBLIC_TLS_CERT_PATH=/etc/lpe-ct/tls/fullchain.pem
LPE_CT_PUBLIC_TLS_KEY_PATH=/etc/lpe-ct/tls/privkey.pem
# LPE-CT terminates IMAPS on 993 and proxies the clear internal IMAP stream
# to the core LPE service. In a split DMZ/LAN deployment, replace 127.0.0.1
# with the private LAN address of the core LPE IMAP listener.
# Do not expose the LPE IMAP bind address publicly.
LPE_CT_IMAPS_BIND_ADDRESS=0.0.0.0:993
LPE_CT_IMAPS_UPSTREAM_ADDRESS=127.0.0.1:1143
LPE_CT_IMAPS_TLS_CERT_PATH=/etc/lpe-ct/tls/fullchain.pem
LPE_CT_IMAPS_TLS_KEY_PATH=/etc/lpe-ct/tls/privkey.pem
# Legacy bootstrap/export file. Runtime management state is persisted in the
# private LPE-CT PostgreSQL dashboard_state table.
LPE_CT_STATE_FILE=/var/lib/lpe-ct/state.json
LPE_CT_SPOOL_DIR=/var/spool/lpe-ct
# Dedicated private PostgreSQL for technical LPE-CT-only state.
# This is the default persisted store for greylisting, reputation, bayespam,
# throttle windows, quarantine metadata, retained mail-flow history indexes,
# admin policy indexes, recipient-verification cache state, DKIM domain
# metadata, and digest scheduling preferences. It must stay private.
LPE_CT_LOCAL_DB_ENABLED=true
LPE_CT_LOCAL_DB_HOST=127.0.0.1
LPE_CT_LOCAL_DB_PORT=5432
LPE_CT_LOCAL_DB_NAME=lpe_ct
LPE_CT_LOCAL_DB_USER=lpe_ct
LPE_CT_LOCAL_DB_PASSWORD=strong-password
# Examples of accepted private scopes:
# host-local, private-backend, lpe-ct-cluster
LPE_CT_LOCAL_DB_NETWORK_SCOPE=host-local
LPE_CT_LOCAL_DB_LISTEN_ADDRESS=127.0.0.1:5432
# Runtime connection string used by LPE-CT to persist technical perimeter state
# into the private local PostgreSQL store. Queue ownership and payload custody
# remain in the spool.
LPE_CT_LOCAL_DB_URL=postgres://lpe_ct:strong-password@127.0.0.1:5432/lpe_ct
LPE_CT_LOCAL_DB_PURPOSES=bayesian,reputation,greylisting,quarantine-metadata,mail-flow-history,policy-indexes,recipient-verification-cache,dkim-config,digest-scheduling,cluster-coordination
# Set to true only for disposable MVP environments where update-lpe-ct.sh
# must wipe the local state file, all spool queues, retained policy artifacts,
# and generated digest reports before redeploy.
LPE_CT_RESET_STATE_ON_UPDATE=false
LPE_CT_BOOTSTRAP_ADMIN_EMAIL=
LPE_CT_BOOTSTRAP_ADMIN_PASSWORD=
# Optional HA role gating for active/passive keepalived-style failover.
# When enabled, /health/ready returns ready only when the file contains "active".
# LPE_CT_HA_ROLE_FILE=/var/lib/lpe-ct/ha-role
# Canonical internal calls from LPE-CT to LPE use the core HTTP listener.
# Default LPE port: 8080. In HA, point this at the core LAN VIP.
# LPE-CT posts to:
#   ${LPE_CT_CORE_DELIVERY_BASE_URL}/internal/lpe-ct/inbound-deliveries
#   ${LPE_CT_CORE_DELIVERY_BASE_URL}/internal/lpe-ct/recipient-verification
#   ${LPE_CT_CORE_DELIVERY_BASE_URL}/internal/lpe-ct/submission-auth
#   ${LPE_CT_CORE_DELIVERY_BASE_URL}/internal/lpe-ct/submissions
# LPE-CT also reverse-proxies public JMAP paths /api/jmap/* to this base URL.
LPE_CT_CORE_DELIVERY_BASE_URL=http://127.0.0.1:8080
# Inbound recipient domains are managed dynamically in the LPE-CT console:
# System Setup -> Mail relay -> Domains. They are stored in PostgreSQL
# dashboard state, matched case-insensitively as exact domains, and subdomains
# must be added as separate accepted domains.
# Optional technical SMTP upstream relays used after LPE-CT has accepted an
# outbound handoff. Port 2525 is not the canonical LPE <-> LPE-CT bridge and
# must not be used for final delivery into LPE or outbound handoff from LPE.
LPE_CT_RELAY_PRIMARY=smtp://10.20.0.12:2525
LPE_CT_RELAY_SECONDARY=smtp://10.20.0.13:2525
LPE_INTEGRATION_SHARED_SECRET=
LPE_CT_MUTUAL_TLS_REQUIRED=false
LPE_CT_FALLBACK_TO_HOLD_QUEUE=false
LPE_CT_DRAIN_MODE=false
LPE_CT_POLICY_ALLOW_SENDERS=
LPE_CT_POLICY_BLOCK_SENDERS=
LPE_CT_POLICY_ALLOW_RECIPIENTS=
LPE_CT_POLICY_BLOCK_RECIPIENTS=
# Internal LPE-backed recipient verification for inbound SMTP.
# LPE-CT caches the verdict locally and does not use SMTP callback verification.
LPE_CT_RECIPIENT_VERIFICATION_ENABLED=false
LPE_CT_RECIPIENT_VERIFICATION_FAIL_CLOSED=true
LPE_CT_RECIPIENT_VERIFICATION_CACHE_TTL_SECONDS=300
# Outbound DKIM signing for configured sender domains.
# Format: domain|selector|private-key-path;domain|selector|private-key-path
LPE_CT_OUTBOUND_DKIM_ENABLED=false
LPE_CT_OUTBOUND_DKIM_KEYS=
LPE_CT_OUTBOUND_DKIM_HEADERS=from,sender,to,cc,subject,mime-version,content-type,message-id
LPE_CT_OUTBOUND_DKIM_OVER_SIGN=true
LPE_CT_OUTBOUND_DKIM_EXPIRATION_SECONDS=3600
# Attachment policy lists are evaluated after MIME extraction and Magika detection.
LPE_CT_ATTACHMENT_ALLOW_EXTENSIONS=
LPE_CT_ATTACHMENT_BLOCK_EXTENSIONS=
LPE_CT_ATTACHMENT_ALLOW_MIME_TYPES=
LPE_CT_ATTACHMENT_BLOCK_MIME_TYPES=
LPE_CT_ATTACHMENT_ALLOW_DETECTED_TYPES=
LPE_CT_ATTACHMENT_BLOCK_DETECTED_TYPES=
LPE_CT_GREYLISTING_ENABLED=true
LPE_CT_ANTIVIRUS_ENABLED=true
LPE_CT_ANTIVIRUS_FAIL_CLOSED=true
LPE_CT_ANTIVIRUS_PROVIDER_CHAIN=takeri
LPE_CT_ANTIVIRUS_TAKERI_BIN=/opt/lpe-ct/bin/Shuhari-CyberForge-CLI
LPE_CT_ANTIVIRUS_TAKERI_ARGS=takeri,scan
LPE_CT_ANTIVIRUS_TAKERI_REPO_URL=https://github.com/AnimeForLife191/Shuhari-CyberForge.git
LPE_CT_ANTIVIRUS_TAKERI_BRANCH=main
LPE_CT_ANTIVIRUS_TAKERI_SYNC_DIR=/opt/lpe-ct/vendor/takeri-src
# Example second provider chained after takeri:
# LPE_CT_ANTIVIRUS_PROVIDER_CHAIN=takeri,clamdscan
# LPE_CT_ANTIVIRUS_CLAMDSCAN_BIN=/usr/bin/clamscan
# LPE_CT_ANTIVIRUS_CLAMDSCAN_ARGS=--stdout,--no-summary,{path}
# LPE_CT_ANTIVIRUS_CLAMDSCAN_INFECTED_MARKERS=found
# LPE_CT_ANTIVIRUS_CLAMDSCAN_SUSPICIOUS_MARKERS=suspicious
# LPE_CT_ANTIVIRUS_CLAMDSCAN_CLEAN_MARKERS=ok
LPE_CT_BAYESPAM_ENABLED=true
LPE_CT_BAYESPAM_AUTO_LEARN=true
LPE_CT_BAYESPAM_SCORE_WEIGHT=6.0
LPE_CT_BAYESPAM_MIN_TOKEN_LENGTH=3
LPE_CT_BAYESPAM_MAX_TOKENS=256
LPE_CT_REQUIRE_SPF=true
LPE_CT_REQUIRE_DKIM_ALIGNMENT=false
LPE_CT_REQUIRE_DMARC_ENFORCEMENT=true
LPE_CT_DEFER_ON_AUTH_TEMPFAIL=true
LPE_CT_DNSBL_ENABLED=true
LPE_CT_DNSBL_ZONES=zen.spamhaus.org,bl.spamcop.net
LPE_CT_REPUTATION_ENABLED=true
LPE_CT_REPUTATION_QUARANTINE_THRESHOLD=-4
LPE_CT_REPUTATION_REJECT_THRESHOLD=-8
LPE_CT_SPAM_QUARANTINE_THRESHOLD=5.0
LPE_CT_SPAM_REJECT_THRESHOLD=9.0
LPE_CT_MAX_MESSAGE_SIZE_MB=64
# Used by check-lpe-ct.sh for a real SMTP delivery probe.
# LPE_CT_SMTP_TEST_SENDER=
# LPE_CT_SMTP_TEST_RECIPIENT=
# Reporting retention, digest cadence, domain defaults, mailbox overrides,
# recipient-verification settings, accepted domains, and DKIM domain references
# are persisted in the private local PostgreSQL store; they are not configured
# through additional env vars here.
RUST_LOG=info
LPE_MAGIKA_BIN=/opt/lpe-ct/bin/magika
LPE_MAGIKA_MIN_SCORE=0.80
