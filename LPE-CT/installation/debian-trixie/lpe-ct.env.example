LPE_CT_BIND_ADDRESS=127.0.0.1:8380
LPE_CT_SMTP_BIND_ADDRESS=0.0.0.0:25
LPE_CT_SERVER_NAME=_
LPE_CT_STATE_FILE=/var/lib/lpe-ct/state.json
LPE_CT_SPOOL_DIR=/var/spool/lpe-ct
# In an active/passive deployment, point to the core LAN VIP.
# LPE_CT_CORE_DELIVERY_BASE_URL=http://10.20.0.40:8080
LPE_CT_RELAY_PRIMARY=smtp://10.20.0.12:2525
LPE_CT_RELAY_SECONDARY=smtp://10.20.0.13:2525
LPE_INTEGRATION_SHARED_SECRET=
LPE_CT_MUTUAL_TLS_REQUIRED=false
LPE_CT_FALLBACK_TO_HOLD_QUEUE=false
LPE_CT_DRAIN_MODE=false
LPE_CT_GREYLISTING_ENABLED=true
LPE_CT_REQUIRE_SPF=true
LPE_CT_REQUIRE_DKIM_ALIGNMENT=false
LPE_CT_REQUIRE_DMARC_ENFORCEMENT=true
LPE_CT_DEFER_ON_AUTH_TEMPFAIL=true
LPE_CT_DNSBL_ENABLED=true
LPE_CT_DNSBL_ZONES=zen.spamhaus.org,bl.spamcop.net
LPE_CT_REPUTATION_ENABLED=true
LPE_CT_REPUTATION_QUARANTINE_THRESHOLD=-4
LPE_CT_REPUTATION_REJECT_THRESHOLD=-8
LPE_CT_SPAM_QUARANTINE_THRESHOLD=5.0
LPE_CT_SPAM_REJECT_THRESHOLD=9.0
LPE_CT_MAX_MESSAGE_SIZE_MB=64
RUST_LOG=info
LPE_MAGIKA_BIN=/opt/lpe-ct/bin/magika
LPE_MAGIKA_MIN_SCORE=0.80
